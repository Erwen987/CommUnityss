<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/welcome_gradient_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <!-- ══════════════════════════
             HEADER
             ══════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Earned Points"
            android:textColor="@android:color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:layout_gravity="center"
            android:layout_marginTop="28dp"
            android:shadowColor="#55000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="6" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Participate and earn rewards for your community!"
            android:textColor="#B3DFFF"
            android:textSize="12sp"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <!-- ══════════════════════════
             TOTAL POINTS CARD
             ══════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL POINTS"
                        android:textColor="#1565C0"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:alpha="0.6" />

                    <TextView
                        android:id="@+id/tvTotalPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,234"
                        android:textColor="#0D47A1"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:lineSpacingMultiplier="0.9"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvProgressLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="266 pts to ₱500 Groceries 🛒"
                        android:textColor="#1976D2"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="6dp" />

                    <ProgressBar
                        android:id="@+id/progressPoints"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:max="100"
                        android:progress="70"
                        android:progressTint="#FFA726"
                        android:progressBackgroundTint="#E3F2FD" />

                </LinearLayout>

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/reward_coins_stack"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════
             SECTION LABEL
             ══════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎁  Choose Your Reward"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:shadowColor="#44000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:layout_marginBottom="12dp" />

        <!-- ══════════════════════════════════════════════
             ROW 1 — Prepaid Load + School Supplies
             Using LinearLayout rows = equal card heights
             ══════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:baselineAligned="false">

            <!-- CARD 1 · Prepaid Load -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvRewardPrepaidLoad"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp"
                    android:gravity="center">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="#FFA726" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prepaid Load 📱"
                        android:textColor="#0D47A1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/reward_prepaid_load"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#FFF8E1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/reward_coins_stack"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100 pts"
                            android:textColor="#E65100"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginStart="6dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClaimPrepaidLoad"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Claim Reward"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:backgroundTint="#FFA726"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 2 · School Supplies -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvRewardSchoolSupplies"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp"
                    android:gravity="center">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="#FFA726" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="School Supplies 🎒"
                        android:textColor="#0D47A1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/reward_school_supplies"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#FFF8E1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/reward_coins_stack"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="300 pts"
                            android:textColor="#E65100"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginStart="6dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClaimSchoolSupplies"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Claim Reward"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:backgroundTint="#FFA726"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════
             ROW 2 — ₱500 Groceries + ₱3,000 Cash
             ══════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- CARD 3 · ₱500 Groceries -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvRewardGroceries500"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp"
                    android:gravity="center">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="#FFA726" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱500 Groceries 🛒"
                        android:textColor="#0D47A1"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/reward_groceries"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#FFF8E1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/reward_coins_stack"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="500 pts"
                            android:textColor="#E65100"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginStart="6dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClaimGroceries500"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Claim Reward"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:backgroundTint="#FFA726"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 4 · ₱3,000 Cash (Premium) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvRewardGroceries3000"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp"
                    android:gravity="center">

                    <!-- Gold accent for premium -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginBottom="6dp"
                        android:background="#FFD740" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ PREMIUM"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:background="#FFA726"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱3,000 Cash 💰"
                        android:textColor="#0D47A1"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/reward_coins_bg"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#FFF8E1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/reward_coins_stack"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1,500 pts"
                            android:textColor="#E65100"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginStart="6dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClaimCash3000"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Claim Reward"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:backgroundTint="#FFA726"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>